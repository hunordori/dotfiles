export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""

plugins=(
  git
  sudo
  z
  docker
  kubectl
  macos
  ubuntu
)

source "$ZSH/oh-my-zsh.sh"

# Handy aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias gs='git status'
alias gd='git diff'

# Better history
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS

# Starship prompt
eval "$(starship init zsh)"
